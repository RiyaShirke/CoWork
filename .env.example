# --- Cowork worker configuration ---
# Override any of these via environment variables or a .env file in the project root.

# --- Folders ---
INBOX_DIR=D:\Cowork\inbox
PROCESSED_DIR=D:\Cowork\processed
FAILED_DIR=D:\Cowork\failed
OUTPUT_DIR=D:\Cowork\output
STATE_DIR=D:\Cowork\state
LOG_DIR=D:\Cowork\logs

# Excel file all rows are appended to (atomic replace on each successful run)
OUTPUT_XLSX=D:\Cowork\output\bills.xlsx

# --- Run policy ---
# How many files to process in one scheduler tick (0 = all queued)
BATCH_LIMIT=1
# After this many file-specific failures on the same file (matched by SHA256),
# the file is moved to FAILED_DIR. Environment failures (Docker/Ollama down,
# workbook locked in Excel) do NOT count against this budget.
RETRY_LIMIT=3
# Hard timeout for OCR docker subprocess (seconds)
SUBPROCESS_TIMEOUT=600
# Lock-file staleness cutoff (seconds). PID-aliveness is also checked.
LOCK_STALE_SECONDS=3600
# Allowed extensions (PDFs preferred; images go straight to OCR)
ALLOWED_EXTS=.pdf,.png,.jpg,.jpeg,.bmp,.tif,.tiff

# --- PaddleOCR (only used for images / scanned PDFs) ---
PADDLE_IMAGE=paddlecloud/paddleocr:2.6-cpu-latest
PADDLE_LANG=en
PADDLE_CACHE_DIR=D:\Cowork\state\paddleocr-cache
# DPI used when rendering scanned PDF pages to images for OCR
PDF_OCR_DPI=200

# --- Ollama ---
OLLAMA_URL=http://localhost:11434
# 8b model is required for reliable structured extraction; 1b will hallucinate.
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=600
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=4096
OLLAMA_KEEP_ALIVE=10m
# Max characters of source text sent to the LLM; longer is more accurate but slower.
OLLAMA_MAX_TEXT_CHARS=24000
# Transport-level retries on ConnectionError / Timeout / HTTP 5xx
OLLAMA_RETRY_ATTEMPTS=3
OLLAMA_RETRY_BACKOFF_SEC=5

# --- Notifications (optional) ---
# Any HTTP endpoint that accepts a JSON POST of {"text": "..."}.
# Slack / Discord / Mattermost / generic webhooks all work.
# Fires when a file is moved to failed/ after exhausting RETRY_LIMIT.
NOTIFY_WEBHOOK_URL=
