# --- Cowork worker configuration ---
# Override any of these via environment variables or a .env file in D:\Cowork

# Watched folder for incoming bill images / PDFs
INBOX_DIR=D:\Cowork\inbox
PROCESSED_DIR=D:\Cowork\processed
FAILED_DIR=D:\Cowork\failed
OUTPUT_DIR=D:\Cowork\output
STATE_DIR=D:\Cowork\state
LOG_DIR=D:\Cowork\logs

# Excel file all rows are appended to
OUTPUT_XLSX=D:\Cowork\output\bills.xlsx

# How many files to process in one run (0 = all available)
BATCH_LIMIT=1

# Allowed file extensions (comma separated, lowercase, with dot)
ALLOWED_EXTS=.png,.jpg,.jpeg,.bmp,.tif,.tiff,.pdf

# --- PaddleOCR (Docker) ---
PADDLE_IMAGE=paddlecloud/paddleocr:2.6-cpu-latest
PADDLE_LANG=en
PADDLE_CACHE_DIR=D:\Cowork\state\paddleocr-cache

# --- Ollama (Docker) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=600
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=1024
OLLAMA_KEEP_ALIVE=10m
OLLAMA_MAX_OCR_CHARS=2000
OLLAMA_MAX_ROWS=12
